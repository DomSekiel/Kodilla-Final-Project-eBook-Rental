              "name": "Puste pola",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "",
                      "// NOTE: This API returns HTTP 200 with body -1 for empty/invalid credentials",
                      "// instead of the more conventional 400 Bad Request. This is the expected behavior",
                      "// for this endpoint and the tests below reflect that.",
                      "",
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test(\"Response body is -1 (empty/invalid credentials indicator)\", function () {",
                      "    var responseText = pm.response.text().trim();",
                      "    var isMinusOneString = responseText === \"-1\";",
                      "    var isMinusOneNumber = Number(responseText) === -1;",
                      "    pm.expect(isMinusOneString || isMinusOneNumber).to.be.true;",
                      "});",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
